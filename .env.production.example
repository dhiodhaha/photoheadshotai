# ─── Database ──────────────────────────────────────────────────────────────────
# Internal Docker network — postgres service name as host
DATABASE_URL=postgresql://photoheadshot:STRONG_PASSWORD_HERE@postgres:5432/photoheadshotdb

# Password for PostgreSQL container (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
BETTER_AUTH_URL=https://yourdomain.com

# Generate with: pnpm dlx @better-auth/cli secret
BETTER_AUTH_SECRET=

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Studio AI <noreply@yourdomain.com>

# ─── AI Generation (fal.ai) ──────────────────────────────────────────────────
FAL_KEY=
MOCK_AI_GENERATION=false
