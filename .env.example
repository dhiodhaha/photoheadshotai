# ============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================================

# Database (PostgreSQL via Docker)
# Connection: postgresql://{user}:{password}@{host}:{port}/{database}
# POSTGRES_PASSWORD: password for the Docker postgres container (dev uses "photoheadshot")
POSTGRES_PASSWORD=photoheadshot
DATABASE_URL="postgresql://photoheadshot:photoheadshot@localhost:5433/photoheadshotdb"

# Better Auth (Authentication)
# BETTER_AUTH_URL: where your app is running (used for OAuth callbacks)
# BETTER_AUTH_SECRET: generate with: pnpm dlx @better-auth/cli secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Cloudflare R2 Storage (File uploads)
# For development:
#   - Use placeholder_account_id + fake credentials for mock mode (no real uploads)
#   - Or get real credentials from https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=placeholder_account_id
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Email Delivery (Resend)
# Sign up at https://resend.com → API Keys → create new key
# Domain verification required for custom from address
RESEND_API_KEY=
RESEND_FROM_EMAIL=Studio AI <noreply@yourdomain.com>

# AI Generation (fal.ai / Seedream v4.5)
# Get API key from https://fal.ai/dashboard/keys
# Set MOCK_AI_GENERATION=true to skip real API calls (dev mode)
FAL_KEY=
MOCK_AI_GENERATION=true
