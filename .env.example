# Database
DATABASE_URL="postgresql://photoheadshot:photoheadshot@localhost:5433/photoheadshotdb"

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate: pnpm dlx @better-auth/cli secret

# Cloudflare R2 Storage
# Set R2_ACCOUNT_ID to "placeholder_account_id" to use mock mode (no real uploads)
R2_ACCOUNT_ID=placeholder_account_id
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Email (Resend)
# Sign up at https://resend.com and create an API key
# Domain verification required for custom from address
RESEND_API_KEY=
RESEND_FROM_EMAIL=Studio AI <noreply@yourdomain.com>

# AI Generation (fal.ai)
# Set MOCK_AI_GENERATION=true to skip real AI calls and return a placeholder image
FAL_KEY=
MOCK_AI_GENERATION=true
