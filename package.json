{
	"name": "photoheadshot",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"start": "node .output/server/index.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "pnpx @biomejs/biome check",
		"lint:fix": "pnpx @biomejs/biome check --write --unsafe",
		"check": "biome check",
		"post-cta-init": "pnpm dlx create-db@latest --user-agent tanstack/tsrouter",
		"db:init": "dotenv -e .env.local -- prisma init",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:push": "dotenv -e .env.local -- prisma db push",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:studio": "dotenv -e .env.local -- prisma studio",
		"db:seed": "dotenv -e .env.local -- prisma db seed",
		"prepare": "husky"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1012.0",
		"@aws-sdk/s3-request-presigner": "^3.1012.0",
		"@base-ui/react": "^1.3.0",
		"@fal-ai/client": "^1.9.4",
		"@hookform/resolvers": "^5.2.2",
		"@prisma/adapter-pg": "^7.4.2",
		"@prisma/client": "^7.4.2",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-query-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"better-auth": "^1.5.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"disposable-email-domains": "^1.0.62",
		"dotenv": "^17.3.1",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^0.577.0",
		"motion": "^12.38.0",
		"next-themes": "^0.4.6",
		"nitro": "^3.0.0",
		"pg": "^8.20.0",
		"prisma": "^7.4.2",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.71.2",
		"react-resizable-panels": "^4.7.3",
		"recharts": "2.15.4",
		"resend": "^6.9.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.3.6",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/pg": "^8.18.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.1.4",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.2",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/engines",
			"esbuild",
			"lightningcss",
			"prisma"
		]
	}
}
