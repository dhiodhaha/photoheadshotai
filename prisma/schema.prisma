generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PhotoStatus {
  pending
  uploaded
  processing
  completed
  failed
}

enum GenerationJobStatus {
  pending
  processing
  completed
  failed
}

enum TransactionType {
  purchase
  generation_deduction
  generation_refund
  referral_reward
  coupon_redemption
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  emailVerified  Boolean  @default(false) @map("email_verified")
  image          String?
  currentCredits Int      @default(0) @map("current_credits")
  referralCode   String   @unique @default(cuid()) @map("referral_code")
  referredBy     String?  @map("referred_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  accounts           Account[]
  photos             Photo[]
  generationJobs     GenerationJob[]
  creditTransactions CreditTransaction[]
  favoriteHeadshots  FavoriteHeadshot[]
  couponRedemptions  CouponRedemption[]

  @@map("users")
}

model BootstrapCode {
  id          String   @id @default(cuid())
  code        String   @unique
  maxRedeems  Int      @default(5) @map("max_redeems")
  redeemCount Int      @default(0) @map("redeem_count")
  createdAt   DateTime @default(now()) @map("created_at")

  redemptions BootstrapRedemption[]

  @@map("bootstrap_codes")
}

model BootstrapRedemption {
  id              String   @id @default(cuid())
  bootstrapCodeId String   @map("bootstrap_code_id")
  userId          String   @unique @map("user_id")
  redeemedAt      DateTime @default(now()) @map("redeemed_at")

  bootstrapCode BootstrapCode @relation(fields: [bootstrapCodeId], references: [id], onDelete: Cascade)

  @@index([bootstrapCodeId])
  @@map("bootstrap_redemptions")
}

model ReferralReward {
  id         String   @id @default(cuid())
  referrerId String   @map("referrer_id")
  newUserId  String   @unique @map("new_user_id")
  amount     Int      @default(10)
  rewardedAt DateTime @default(now()) @map("rewarded_at")

  @@index([referrerId])
  @@map("referral_rewards")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Photo {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  key              String   @unique
  filename         String
  contentType      String   @map("content_type")
  size             Int
  status           PhotoStatus @default(pending)
  hasFaceDetected  Boolean? @map("has_face_detected")
  createdAt        DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]

  @@index([userId])
  @@index([status])
  @@map("photos")
}

model GenerationJob {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  photoId       String    @map("photo_id")
  styleId       String    @default("") @map("style_id")
  stylePrompt   String    @map("style_prompt")
  status        GenerationJobStatus @default(pending)
  costCredits   Int                @map("cost_credits")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo              Photo               @relation(fields: [photoId], references: [id], onDelete: Cascade)
  generatedHeadshots GeneratedHeadshot[]

  @@index([userId])
  @@index([photoId])
  @@index([status])
  @@map("generation_jobs")
}

model GeneratedHeadshot {
  id              String   @id @default(cuid())
  generationJobId String   @map("generation_job_id")
  resultUrl       String   @map("result_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  r2Key           String?  @map("r2_key")
  r2ThumbnailKey  String?  @map("r2_thumbnail_key")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  createdAt       DateTime @default(now()) @map("created_at")

  generationJob GenerationJob      @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  favorites     FavoriteHeadshot[]

  @@index([generationJobId])
  @@map("generated_headshots")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  amount          Int
  transactionType TransactionType @map("transaction_type")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_transactions")
}

model FavoriteHeadshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id")
  headshotId  String   @map("headshot_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  headshot GeneratedHeadshot @relation(fields: [headshotId], references: [id], onDelete: Cascade)

  @@unique([userId, headshotId])
  @@index([userId])
  @@index([headshotId])
  @@map("favorite_headshots")
}

model Coupon {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  credits     Int
  maxRedeems  Int      @default(1) @map("max_redeems")
  redeemCount Int      @default(0) @map("redeem_count")
  expiresAt   DateTime? @map("expires_at")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")

  redemptions CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id")
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}
